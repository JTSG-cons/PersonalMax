# PersonalMax environment variables
# Copy to .env.local and fill in from your Supabase project settings (API section).
# Only these two values are needed — the app has NO service-role key by design:
# all privileged game-state writes happen inside SECURITY DEFINER Postgres functions.

# Your Supabase project URL, e.g. https://abcdefghijklm.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The *publishable* (anon) API key. Safe to expose to browsers; Row Level
# Security is the enforcement layer. Never put a secret/service_role key here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
